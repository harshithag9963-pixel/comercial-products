{
  "name": "commercial-product-page",
  "version": "1.0.0",
  "description": "Professional commercial product listing page",
  "main": "server/index.js",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm ci --include=dev && npm run build",
    "start": "node server/index.js",
    "db:setup": "node server/db/setup.js",
    "db:seed": "node server/db/seed.js",
    "db:seed:users": "node server/db/seed-users.js"
  },
  "keywords": [
    "products",
    "commercial",
    "mern"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": "22.x"
  }
}
